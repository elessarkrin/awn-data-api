# Ambient Weather API credentials
AWN_API_KEY=your_api_key_here
AWN_APPLICATION_KEY=your_application_key_here
AWN_MAC_ADDRESS=your_device_mac_address

# Data collection interval in seconds (default: 60)
COLLECTION_INTERVAL_SECONDS=60

# Number of days to retain daily readings (default: 365)
DAILY_RETENTION_DAYS=365

# Historical backfill settings
# How many days of history to fetch on startup (default: 365)
BACKFILL_DAYS=365
# Seconds between API requests during backfill (default: 1.1, AWN rate limit is 1 req/sec)
BACKFILL_REQUEST_DELAY=1.1

# Database URL (default: SQLite)
DATABASE_URL=sqlite+aiosqlite:///./weather.db

# Comma-separated origins allowed to call the API from browsers
CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# Astronomy API (ipgeolocation.io)
ASTRONOMY_API_KEY=your_astronomy_api_key_here
LAT=40.7128
LON=-74.0060

# React build output directory served by the API at /app
REACT_BUILD_DIR=frontend/dist

# API response compression (gzip)
GZIP_MINIMUM_SIZE=500
GZIP_COMPRESSLEVEL=6
